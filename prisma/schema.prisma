generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  location      String?
  socialLinks   String?   @db.Text
  additionalNotes String? @db.Text
  password      String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  reviews   Review[]
  cart      Cart?
  orders    Order[]
  addresses Address[]

  @@index([email])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
}

// ─── Brand (managed via Settings) ──────────────────────

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([slug])
}

model Product {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  description      String    @db.Text
  brand            String?
  model            String?
  tags             String?
  condition        String?   @default("New")
  weight           Decimal?  @db.Decimal(10, 2)
  price            Decimal   @db.Decimal(10, 2)
  compareAtPrice   Decimal?  @db.Decimal(10, 2)
  globalPrice      Decimal?  @db.Decimal(10, 2)
  buyingPrice      Decimal?  @db.Decimal(10, 2)
  competitorsPrice Decimal?  @db.Decimal(10, 2)
  shippingCost     Decimal?  @db.Decimal(10, 2)
  handlerCost      Decimal?  @db.Decimal(10, 2)
  stock            Int       @default(0)
  isFeatured       Boolean   @default(false)
  showPrice        Boolean   @default(true)
  isActive         Boolean   @default(true)
  sku              String    @unique
  categoryId       String
  // SEO fields
  metaTitle        String?
  metaDescription  String?   @db.Text
  ogImage          String?   @db.Text
  focusKeyphrase   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  category        Category          @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  reviews         Review[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  relatedTo       RelatedProduct[]  @relation("ProductRelation")
  relatedFrom     RelatedProduct[]  @relation("RelatedProductRelation")

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
}

model RelatedProduct {
  productId        String
  relatedProductId String

  product        Product @relation("ProductRelation", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedProductRelation", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@id([productId, relatedProductId])
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String  @db.Text
  alt       String?
  title     String?
  position  Int     @default(0)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  cartId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   Int         @default(autoincrement())
  userId        String
  status        OrderStatus @default(PENDING)
  subtotal      Decimal     @db.Decimal(10, 2)
  shippingCost  Decimal     @db.Decimal(10, 2) @default(0)
  tax           Decimal     @db.Decimal(10, 2) @default(0)
  total         Decimal     @db.Decimal(10, 2)
  totalCosts    Decimal?    @db.Decimal(10, 2)
  totalProfit   Decimal?    @db.Decimal(10, 2)
  isManualOrder Boolean     @default(false)
  notes         String?     @db.Text
  stripePaymentIntentId String?
  shippingAddressId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  shippingAddress Address?    @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model OrderItem {
  id               String   @id @default(uuid())
  quantity         Int
  price            Decimal  @db.Decimal(10, 2)
  costs            Decimal? @db.Decimal(10, 2)
  profit           Decimal? @db.Decimal(10, 2)
  discount         Decimal? @db.Decimal(10, 2)
  competitorsPrice Decimal? @db.Decimal(10, 2)
  globalPrice      Decimal? @db.Decimal(10, 2)
  basePrice        Decimal? @db.Decimal(10, 2)
  orderId          String
  productId        String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String  @default("US")
  isDefault  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordersAsShipping Order[] @relation("OrderShippingAddress")

  @@index([userId])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  title     String?
  comment   String?  @db.Text
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

// ─── Settings / Brand ─────────────────────────────────

model BrandSetting {
  id             String  @id @default(uuid())
  brandName      String  @default("Koncells")
  phone          String?
  emails         String? @db.Text
  address        String? @db.Text
  iconUrl        String?
  verticalLogo   String?
  horizontalLogo String?
  updatedAt      DateTime @updatedAt
}

// ─── SEO Settings ─────────────────────────────────────

model SeoSettings {
  id                 String  @id @default(uuid())
  showInProductForm  Boolean @default(true)
  updatedAt          DateTime @updatedAt
}

// ─── Image Processing Settings (sharp) ────────────────

model ImageSettings {
  id               String   @id @default(uuid())
  // Resize
  resizeEnabled    Boolean  @default(true)
  resizeWidth      Int      @default(1200)
  resizeHeight     Int      @default(1200)
  resizeFit        String   @default("inside")   // "inside", "cover", "contain", "fill", "outside"
  // Watermark
  watermarkEnabled Boolean  @default(true)
  watermarkText    String   @default("Koncells")
  watermarkOpacity Float    @default(0.5)        // 0–1
  watermarkSize    Int      @default(48)         // bar height in px
  watermarkPosition String  @default("southeast") // "southeast", "southwest", "northeast", "northwest"
  // Output
  outputFormat     String   @default("webp")     // "webp" or "jpeg"
  outputQuality    Int      @default(85)         // 1–100
  updatedAt        DateTime @updatedAt
}

// ─── Exchange Rates ───────────────────────────────────

model ExchangeRate {
  id        String   @id @default(uuid())
  source    String   // "CNY" or "USD"
  target    String   // "LKR"
  rate      Decimal  @db.Decimal(12, 4)
  isDefault Boolean  @default(false)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// ─── Database Backup ──────────────────────────────────

model Backup {
  id        String   @id @default(uuid())
  name      String
  filename  String
  size      Int      // bytes
  createdAt DateTime @default(now())
}
